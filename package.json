{
	"name": "@difyz/n8n-nodes-volcengine",
	"version": "1.0.16",
	"description": "n8n community node — Volcengine Ark (火山方舟) Doubao Chat Model, Seedream Image Generation, Seedance Video Generation (OpenAI-compatible API, thinking mode).",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"volcengine",
		"ark",
		"doubao",
		"seedream",
		"seedance",
		"image",
		"video",
		"generation",
		"langchain",
		"ai",
		"llm",
		"file",
		"upload",
		"files"
	],
	"license": "MIT",
	"author": "Difyz",
	"homepage": "https://github.com/difyz9/n8n-nodes-volcengine#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/difyz9/n8n-nodes-volcengine.git"
	},
	"bugs": {
		"url": "https://github.com/difyz9/n8n-nodes-volcengine/issues"
	},
	"main": "dist/nodes/VolcengineArkNextChatModel/VolcengineArkNextChatModel.node.js",
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"clean": "rm -rf dist",
		"lint:fix": "n8n-node lint --fix",
		"pack:check": "npm pack --dry-run",
		"release:check": "node scripts/release-check.mjs",
		"release": "node scripts/release.mjs",
		"prepublishOnly": "node scripts/prepublish-only.mjs"

	},
	"files": [
		"dist",
		"scripts/materialize-hosted-nested-deps.cjs",
		"README.md",
		"LICENSE"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"credentials": [
			"dist/credentials/VolcengineArkNextApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/VolcengineArkNextChatModel/VolcengineArkNextChatModel.node.js",
			"dist/nodes/VolcengineArkNextImageModel/VolcengineArkNextImageModel.node.js",
			"dist/nodes/VolcengineArkNextVideoModel/VolcengineArkNextVideoModel.node.js",
			"dist/nodes/VolcengineArkNextFileModel/VolcengineArkNextFileModel.node.js"
		]
	},
	"dependencies": {
		"@langchain/core": "1.1.42",
		"@langchain/openai": "1.4.5",
		"@n8n/ai-utilities": "0.14.1",
		"undici": "6.25.0"
	},
	"bundledDependencies": [
		"@langchain/core",
		"@langchain/openai",
		"@n8n/ai-utilities",
		"undici"
	],
	"devDependencies": {
		"@n8n/eslint-plugin-community-nodes": "^0.15.0",
		"@types/node": "^22.0.0",
		"copyfiles": "^2.4.1",
		"eslint": "^9.29.0",
		"n8n-workflow": ">=1.82.0",
		"typescript": "~5.7.0"
	},
	"peerDependencies": {
		"n8n-workflow": ">=1.82.0"
	},
	"engines": {
		"node": ">=22.16"
	}
}
